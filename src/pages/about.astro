---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="About — Alice Zhou" description="About Alice Zhou — UX Designer and Front-End Developer">

  <!-- Spinner distorted: fixed to viewport top-right (hidden for now) -->
  <div class="about-page-lottie fixed top-0 right-0 w-[min(55vw,55vh)] aspect-square pointer-events-none hidden overflow-hidden z-0" aria-hidden="true">
    <div class="about-page-lottie-inner absolute -top-1/2 -left-1/2 w-[200%] h-[200%] flex items-center justify-center">
      <video
        src="/animations/spinner%20distorted.webm"
        autoplay
        loop
        muted
        playsinline
        class="w-full h-full object-contain opacity-20"
        aria-hidden="true"
      />
    </div>
  </div>

  <!-- Bio Section -->
  <section class="max-w-5xl mx-auto px-6 md:px-16 pt-32 pb-20 relative overflow-visible">

    <div class="grid grid-cols-1 md:grid-cols-[1.2fr_1fr] gap-12 md:gap-16 items-stretch">
      <!-- Left column -->
      <div>
        <p class="font-body text-2xl text-charcoal-600 mb-1">Hi, I'm</p>
        <h1
          class="font-about-name italic text-charcoal-700 leading-none mb-8 block"
          style="font-size: clamp(3rem, 18vw, 200pt);"
        >
          Alice
        </h1>
        <p class="font-body text-base leading-relaxed text-charcoal-600 max-w-lg">
          As a designer, I believe that a product is an investment that should grow with, and easily adapt to its user. My approach to work, life, and design is to freely draw connections in even the most unlikely topics. I believe this common ground through exchange of ideas and information is truly the key to innovative products. In my current Product Design + Front-End Development role, I am tackling both creation and implementation. Through these responsibilities, I've gained a more holistic view on design.
        </p>
      </div>

      <!-- Right column: photo and caption aligned to bottom -->
      <div class="flex flex-col justify-end gap-6">
        <img
          src="/images/about/alicezhou.png"
          alt="Alice Zhou"
          class="rounded-lg aspect-[3/2] w-full object-cover"
          loading="eager"
          decoding="async"
        />
        <div class="font-accent">
          <p class="text-sm font-semibold text-charcoal-700">Tufts University</p>
          <p class="text-sm text-charcoal-500">
            B.S. Human Factors Engineering | Minor in Engineering Management
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Interests / Contact Strip: full-width background, text same width as rest of page -->
  <section id="contact" class="bg-dark py-14 md:py-20">
    <div class="max-w-5xl mx-auto px-6 md:px-16">
      <p class="font-body text-base md:text-lg leading-relaxed text-on-dark mb-8">
        Outside of work, you'll find me combing through thrift stores, maintaining my Duolingo streak, or rallying my friends for our next music festival.
      </p>
      <h2 class="font-heading text-5xl md:text-6xl lg:text-7xl text-on-dark mb-4">Contact Me</h2>
      <div class="flex items-center gap-8">
        <a href="#" class="font-body text-base tracking-wider text-on-dark underline underline-offset-4 decoration-on-dark/60 hover:opacity-80 transition-opacity">
          resume
        </a>
        <a href="mailto:alzce03@gmail.com" class="font-body text-base tracking-wider text-on-dark underline underline-offset-4 decoration-on-dark/60 hover:opacity-80 transition-opacity">
          email
        </a>
        <a href="https://www.linkedin.com/in/alzce/" target="_blank" rel="noopener" class="font-body text-base tracking-wider text-on-dark underline underline-offset-4 decoration-on-dark/60 hover:opacity-80 transition-opacity">
          linkedin
        </a>
      </div>
    </div>
  </section>

  <!--
    Image collage (Figma 569:1126): two rows, gap 32px.
    Row 1 — Figma 569:1127: flex items-center justify-between; side wrappers self-stretch +
    inner aspect h-full; center 300×400; jewelry crop in overflow clip.
  -->
  <section class="px-6 md:px-16 py-20" aria-label="Selected work and projects">
    <div class="max-w-5xl mx-auto w-full flex flex-col gap-6 md:gap-8">
      <!--
        Row 1 (569:1127): widths from row inline size (100% = row width here), height from aspect.
        Do not use 100% inside a custom prop for height — it resolves against parent height and collapses.
      -->
      <div
        class="flex w-full flex-col gap-3 md:gap-4 lg:flex-row lg:items-center lg:justify-between lg:gap-8"
      >
        <figure
          class="relative aspect-[2000/1814] w-full min-h-[180px] shrink-0 overflow-hidden rounded-xl bg-charcoal-100 lg:min-h-0 lg:min-w-0 lg:w-[calc((100%-4rem)*(2000/1814)/((2000/1814)+(300/400)+(342/308)))] lg:max-w-full"
        >
          <img
            src="/images/about/laser%20engraved%20pendants%201.png"
            alt="Laser engraved pendants in a frame"
            class="pointer-events-none absolute inset-0 size-full max-w-none object-cover"
            loading="lazy"
            decoding="async"
          />
        </figure>
        <figure
          class="relative mx-auto aspect-[3/4] w-full max-w-[300px] min-h-[200px] shrink-0 overflow-hidden rounded-xl bg-charcoal-100 lg:mx-0 lg:max-w-full lg:w-[calc((100%-4rem)*(300/400)/((2000/1814)+(300/400)+(342/308)))]"
        >
          <img
            src="/images/about/capstone%20team.png"
            alt="Capstone team in front of a presentation screen"
            class="pointer-events-none absolute inset-0 size-full max-w-none object-cover"
            loading="lazy"
            decoding="async"
          />
        </figure>
        <figure
          class="relative aspect-[342/308] w-full min-h-[180px] shrink-0 overflow-hidden rounded-xl bg-charcoal-100 lg:min-h-0 lg:min-w-0 lg:w-[calc((100%-4rem)*(342/308)/((2000/1814)+(300/400)+(342/308)))] lg:max-w-full"
        >
          <div class="pointer-events-none absolute inset-0 overflow-hidden">
            <img
              src="/images/about/jewelry%20project.jpg"
              alt="Jewelry design — small metal charms"
              class="absolute h-[186.86%] w-[126.21%] max-w-none object-cover pointer-events-none left-[-13.01%] top-[-48.63%]"
              loading="lazy"
              decoding="async"
            />
          </div>
        </figure>
      </div>

      <!-- Row 2 (569:1131): same idea — width % + aspect; one gap between two panels -->
      <div
        class="flex w-full flex-col gap-3 md:gap-4 lg:flex-row lg:items-center lg:justify-between lg:gap-8"
      >
        <figure
          class="relative aspect-[518/503] w-full min-h-[200px] shrink-0 overflow-hidden rounded-xl bg-charcoal-100 lg:min-h-0 lg:min-w-0 lg:w-[calc((100%-2rem)*(518/503)/((518/503)+(2012/1420)))] lg:max-w-full"
        >
          <div class="pointer-events-none absolute inset-0 overflow-hidden">
            <img
              src="/images/about/haven%20presentation%201.png"
              alt="Presenting the Haven project"
              class="pointer-events-none absolute inset-0 size-full max-w-none object-cover object-center"
              loading="lazy"
              decoding="async"
            />
          </div>
        </figure>
        <figure
          class="relative aspect-[2012/1420] w-full min-h-[200px] shrink-0 overflow-hidden rounded-xl bg-charcoal-100 lg:min-h-0 lg:min-w-0 lg:w-[calc((100%-2rem)*(2012/1420)/((518/503)+(2012/1420)))] lg:max-w-full"
        >
          <img
            src="/images/about/topsters%201.png"
            alt="Topsters project — grid of album art"
            class="pointer-events-none absolute inset-0 size-full max-w-none object-cover"
            loading="lazy"
            decoding="async"
          />
        </figure>
      </div>
    </div>
  </section>

</BaseLayout>
