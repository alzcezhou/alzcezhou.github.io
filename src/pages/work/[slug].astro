---
import { getCollection, render } from "astro:content";
import CaseStudyLayout from "../../layouts/CaseStudyLayout.astro";
import FullWidthDarkBanner from "../../components/FullWidthDarkBanner.astro";
import HavenPitchPill from "../../components/HavenPitchPill.astro";
import HavenSlideshow from "../../components/HavenSlideshow.astro";
import SkipLegalResearchInsights from "../../components/SkipLegalResearchInsights.astro";

export async function getStaticPaths() {
  const entries = await getCollection("work");
  const sorted = [...entries].sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999));
  return sorted.map((entry, index) => {
    const otherProjects = sorted
      .filter((_, i) => i !== index)
      .map((e) => ({ slug: e.id, title: e.data.title }));
    return {
      params: { slug: entry.id },
      props: { entry, otherProjects },
    };
  });
}

const { entry, otherProjects = [] } = Astro.props;
const { Content } = await render(entry);
---

<CaseStudyLayout
  title={entry.data.title}
  year={entry.data.year}
  role={entry.data.role}
  category={entry.data.category}
  responsibilities={entry.data.responsibilities}
  results={entry.data.results}
  cover={entry.id === "haven" ? "/images/haven/header.png" : entry.data.cover}
  coverAlt={entry.data.coverAlt}
  coverFillHeight={true}
  contentMaxWidth={1128}
  headingExpandsRight={entry.id === "eifu-marketing-site"}
  coverAlignBottom={entry.id === "eifu-marketing-site"}
  otherProjects={otherProjects}
>
  <Content components={entry.id === "haven" ? { FullWidthDarkBanner, HavenPitchPill, HavenSlideshow } : entry.id === "skiplegal" ? { SkipLegalResearchInsights } : undefined} />
</CaseStudyLayout>
