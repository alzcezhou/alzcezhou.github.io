---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Spinner from "../components/Spinner.astro";
import ProjectCard from "../components/ProjectCard.astro";

const projects = (await getCollection("work")).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<BaseLayout title="Alice Zhou — Portfolio">

  <!-- Hero -->
  <section class="min-h-[80vh] flex items-center justify-center relative overflow-hidden pt-16">
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
      <Spinner size={600} class="text-charcoal-700 opacity-35" />
    </div>
    <h1 class="font-display text-7xl md:text-[8.5rem] text-charcoal-700 relative z-10 text-center leading-none">
      Alice Zhou
    </h1>
  </section>

  <!-- Tagline -->
  <div class="bg-taupe-400/80 py-4">
    <p class="font-body text-[11px] md:text-xs tracking-[0.2em] text-center text-charcoal-600 uppercase">
      product designer &amp; front end developer at enlabel global services
    </p>
  </div>

  <!-- Projects -->
  <section id="work" class="max-w-[1206px] mx-auto px-6 md:px-12 py-16 md:py-24">
    <div class="flex flex-col gap-8 md:gap-10">
      {projects.map((project) => (
        <ProjectCard
          title={project.data.title}
          description={project.data.description}
          category={project.data.category}
          href={`/work/${project.id}`}
          coverAlt={project.data.coverAlt}
        />
      ))}
    </div>
  </section>

</BaseLayout>
