---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import TextureOverlay from "../components/TextureOverlay.astro";
import ProjectCard from "../components/ProjectCard.astro";

const projects = (await getCollection("work")).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<BaseLayout title="Alice Zhou — Portfolio">

  <!-- Hero + Tagline: first viewport has hero filling space, band aligned to bottom; then scrolls normally -->
  <div class="min-h-screen flex flex-col">
    <section class="min-h-0 flex-1 flex items-center justify-center relative overflow-hidden pt-16">
      <div class="absolute inset-0 flex items-center justify-center pointer-events-none" aria-hidden="true">
        <video
          id="hero-spinner"
          src="/animations/final%20spinner.webm?v=3"
          autoplay
          loop
          muted
          playsinline
          class="w-[800px] max-w-[90vw] max-h-[80vh] object-contain opacity-35"
          aria-hidden="true"
        />
      </div>
      <TextureOverlay size={6} radius={5.3} opacity={0.25} />
      <h1 class="font-display font-normal leading-normal text-[#000] relative z-10 text-center whitespace-nowrap -translate-y-[5%]" style="font-size: clamp(2.5rem, 12vw, 16rem);">
        Alice Zhou
      </h1>
    </section>
    <script>
      (function () {
        const video = document.getElementById("hero-spinner");
        if (!video) return;
        video.playbackRate = 0.75;
        video.addEventListener("loadedmetadata", function () {
          this.playbackRate = 0.75;
        });
      })();
    </script>

    <div class="bg-dark py-2 flex-shrink-0">
      <p class="font-accent font-normal leading-normal text-[#FFF] text-center" style="font-size: clamp(0.5rem, 1.69vw, 2.25rem);">
        product designer &amp; front end developer at enlabel global services
      </p>
    </div>
  </div>

  <!-- Projects -->
  <section id="work" class="max-w-[1206px] mx-auto px-6 md:px-12 py-16 md:py-24">
    <div class="flex flex-col gap-8 md:gap-10">
      {projects.map((project) => (
        <ProjectCard
          title={project.data.title}
          description={project.data.description}
          category={project.data.category}
          href={`/work/${project.id}`}
          cover={project.data.cover}
          coverAlt={project.data.coverAlt}
        />
      ))}
    </div>
  </section>

</BaseLayout>
