---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  year: string;
  role: string;
  category?: string;
  responsibilities?: string[];
  results?: string[];
  cover?: string;
  coverAlt?: string;
  /** When true, image fills height of header column (e.g. Haven header.png) */
  coverFillHeight?: boolean;
  /** Optional max width (px) for all content, e.g. 1128 for Haven */
  contentMaxWidth?: number;
}

const {
  title,
  year,
  role,
  category,
  responsibilities = [],
  results = [],
  cover,
  coverAlt,
  coverFillHeight,
  contentMaxWidth,
} = Astro.props;
---

<BaseLayout title={`${title} — Alice Zhou`}>
  <article>
    <div
      class:list={[contentMaxWidth != null && "mx-auto"]}
      style={contentMaxWidth != null ? `max-width: ${contentMaxWidth}px` : undefined}
    >
    <!-- Above the fold: heading + meta + cover, centered in viewport -->
    <header class="min-h-screen flex items-center justify-center px-6 md:px-16 lg:px-24 py-16">
      <div class={`grid grid-cols-1 lg:grid-cols-[1fr_1.6fr] gap-12 w-full ${coverFillHeight ? "items-stretch" : "items-start"}`}>
        <div class="space-y-6">
          <h1 class="font-heading text-5xl md:text-6xl font-light text-on-light leading-tight">
            {title}
          </h1>
          <div class="flex flex-col gap-0 mt-0">
            <p class="font-accent text-[32px] text-on-light py-0 my-0">
              {year}
            </p>
            <p class="font-accent text-[32px] text-on-light py-0 my-0">
              Role: <span class="underline">{role}</span>
            </p>
          </div>

          {responsibilities.length > 0 && (
            <div class="pt-2">
              <h2 class="font-body text-base font-semibold text-on-light mb-2">Responsibilities</h2>
              <ul class="space-y-1.5 font-body text-base text-on-light">
                {responsibilities.map((r) => (
                  <li key={r}>{r}</li>
                ))}
              </ul>
            </div>
          )}

          {results.length > 0 && (
            <div class="pt-2">
              <h2 class="font-body text-base font-semibold text-on-light mb-2">Results</h2>
              <ul class="space-y-1.5 font-body text-base text-on-light">
                {results.map((r) => (
                  <li key={r}>{r}</li>
                ))}
              </ul>
            </div>
          )}
        </div>

        {cover ? (
          coverFillHeight ? (
            <div class="min-h-[40vh] lg:min-h-0 h-full flex overflow-hidden">
              <img
                src={cover}
                alt={coverAlt ?? title}
                class="rounded-2xl w-full h-full min-h-[40vh] lg:min-h-0 object-contain object-center"
                loading="eager"
                decoding="async"
              />
            </div>
          ) : (
            <img
              src={cover}
              alt={coverAlt ?? title}
              class="rounded-2xl aspect-[16/10] w-full object-cover"
              loading="eager"
              decoding="async"
            />
          )
        ) : (
          <div class="img-placeholder rounded-2xl aspect-[16/10] w-full"></div>
        )}
      </div>
    </header>

    <section
      class:list={[
        "px-6 md:px-16 lg:px-24 py-16 mx-auto",
        contentMaxWidth == null && "max-w-4xl",
        "[&_h2]:font-heading [&_h2]:text-3xl [&_h2]:md:text-4xl [&_h2]:italic [&_h2]:text-on-light [&_h2]:mt-16 [&_h2]:mb-6",
        "[&_h3]:font-heading [&_h3]:text-2xl [&_h3]:text-on-light [&_h3]:mt-10 [&_h3]:mb-4",
        "[&_p]:font-body [&_p]:text-on-light [&_p]:leading-relaxed [&_p]:mb-6 [&_p]:text-base",
        "[&_ul]:list-disc [&_ul]:pl-6 [&_ul]:mb-6 [&_ul]:space-y-2 [&_ul]:text-on-light",
        "[&_ol]:list-decimal [&_ol]:pl-6 [&_ol]:mb-6 [&_ol]:space-y-2 [&_ol]:text-on-light",
        "[&_blockquote]:border-l-2 [&_blockquote]:border-taupe-500 [&_blockquote]:pl-6 [&_blockquote]:italic [&_blockquote]:text-on-light [&_blockquote]:my-8",
        "[&_img]:rounded-xl [&_img]:my-8 [&_img]:w-full",
        "[&_strong]:text-on-light [&_strong]:font-semibold",
      ]}
    >
      <slot />
      <slot name="appScreens" />
    </section>

    <nav class="px-6 md:px-16 lg:px-24 pb-24">
      <a
        href="/"
        class="inline-flex items-center gap-2 font-body text-sm tracking-wider uppercase text-on-light hover:opacity-80 transition-opacity"
      >
        <span aria-hidden="true">&larr;</span> All Projects
      </a>
    </nav>
    </div>
  </article>
</BaseLayout>
