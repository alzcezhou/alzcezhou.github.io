---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  subtitle?: string;
  year: string;
  role: string;
  category?: string;
  responsibilities?: string[];
  results?: string[];
}

const {
  title,
  subtitle,
  year,
  role,
  category,
  responsibilities = [],
  results = [],
} = Astro.props;
---

<BaseLayout title={`${title} — Alice Zhou`}>
  <article>
    <header class="px-6 md:px-16 lg:px-24 pt-32 pb-16">
      <p class="font-body text-sm tracking-widest uppercase text-taupe-600 mb-4">
        {year}{category && ` · ${category}`}
      </p>
      <h1 class="font-heading text-5xl md:text-7xl font-light text-charcoal-700 leading-tight">
        {title}
      </h1>
      {subtitle && (
        <p class="font-heading text-xl md:text-2xl text-taupe-600 mt-4 italic">
          {subtitle}
        </p>
      )}

      <div class="mt-12 grid grid-cols-1 lg:grid-cols-[1fr_1.6fr] gap-12 items-start">
        <div class="space-y-8">
          <div>
            <h2 class="font-body text-xs tracking-widest uppercase text-taupe-500 mb-2">Role</h2>
            <p class="font-body text-charcoal-600">{role}</p>
          </div>

          {responsibilities.length > 0 && (
            <div>
              <h2 class="font-body text-xs tracking-widest uppercase text-taupe-500 mb-2">Responsibilities</h2>
              <ul class="space-y-1">
                {responsibilities.map((r) => (
                  <li class="font-body text-charcoal-600 text-sm">{r}</li>
                ))}
              </ul>
            </div>
          )}

          {results.length > 0 && (
            <div>
              <h2 class="font-body text-xs tracking-widest uppercase text-taupe-500 mb-2">Results</h2>
              <ul class="space-y-1">
                {results.map((r) => (
                  <li class="font-body text-charcoal-600 text-sm">{r}</li>
                ))}
              </ul>
            </div>
          )}
        </div>

        <div class="img-placeholder rounded-2xl aspect-[16/10] w-full"></div>
      </div>
    </header>

    <section class="px-6 md:px-16 lg:px-24 py-16 max-w-4xl mx-auto
      [&_h2]:font-heading [&_h2]:text-3xl [&_h2]:md:text-4xl [&_h2]:italic [&_h2]:text-charcoal-700 [&_h2]:mt-16 [&_h2]:mb-6
      [&_h3]:font-heading [&_h3]:text-2xl [&_h3]:text-charcoal-600 [&_h3]:mt-10 [&_h3]:mb-4
      [&_p]:font-body [&_p]:text-charcoal-600 [&_p]:leading-relaxed [&_p]:mb-6 [&_p]:text-base
      [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:mb-6 [&_ul]:space-y-2 [&_ul]:text-charcoal-600
      [&_ol]:list-decimal [&_ol]:pl-6 [&_ol]:mb-6 [&_ol]:space-y-2 [&_ol]:text-charcoal-600
      [&_blockquote]:border-l-2 [&_blockquote]:border-taupe-500 [&_blockquote]:pl-6 [&_blockquote]:italic [&_blockquote]:text-taupe-600 [&_blockquote]:my-8
      [&_img]:rounded-xl [&_img]:my-8 [&_img]:w-full
      [&_strong]:text-charcoal-700 [&_strong]:font-semibold">
      <slot />
    </section>

    <nav class="px-6 md:px-16 lg:px-24 pb-24">
      <a
        href="/"
        class="inline-flex items-center gap-2 font-body text-sm tracking-wider uppercase text-taupe-600 hover:text-charcoal-700 transition-colors"
      >
        <span aria-hidden="true">&larr;</span> All Projects
      </a>
    </nav>
  </article>
</BaseLayout>
