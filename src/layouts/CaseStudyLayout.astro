---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  year: string;
  role: string;
  category?: string;
  /** Header pills (black labels) */
  tags?: string[];
  /** Header timeline line, e.g. "3 months" */
  timeline?: string;
  team?: string[];
  responsibilities?: string[];
  tools?: string[];
  results?: string[];
  cover?: string;
  coverAlt?: string;
  /** When true, image fills height of header column (e.g. Haven header.png) */
  coverFillHeight?: boolean;
  /** Optional max width (px) for all content, e.g. 1128 for Haven */
  contentMaxWidth?: number;
  /** When true, main heading extends to the right outside the content constraint and wraps to ~2 lines */
  headingExpandsRight?: boolean;
  /** When true, cover image in header aligns to the bottom of its div */
  coverAlignBottom?: boolean;
  /** Other work projects to link to (e.g. [{ slug, title }, { slug, title }]) */
  otherProjects?: { slug: string; title: string }[];
}

const {
  title,
  year,
  role,
  category,
  tags = [],
  timeline,
  team = [],
  responsibilities = [],
  tools = [],
  results = [],
  cover,
  coverAlt,
  coverFillHeight,
  contentMaxWidth,
  headingExpandsRight,
  coverAlignBottom,
  otherProjects = [],
} = Astro.props;
---

<BaseLayout title={`${title} — Alice Zhou`}>
  <article>
    <div
      class:list={[contentMaxWidth != null && "mx-auto"]}
      style={contentMaxWidth != null ? `max-width: ${contentMaxWidth}px` : undefined}
    >
    <!-- Above the fold: heading + meta + cover, centered in viewport -->
    <header class="min-h-screen flex items-center justify-center px-6 md:px-16 lg:px-24 py-16">
      <div class={`grid grid-cols-1 lg:grid-cols-[1fr_1.6fr] gap-12 w-full ${coverFillHeight ? "items-stretch" : "items-start"}`}>
        <div class="space-y-6">
          {headingExpandsRight ? (
            <div class="heading-expand-right">
              <h1 class="font-heading text-5xl md:text-6xl font-light text-on-light leading-tight heading-two-lines">
                {title}
              </h1>
            </div>
          ) : (
            <h1 class="font-heading text-5xl md:text-6xl font-light text-on-light leading-tight">
              {title}
            </h1>
          )}
          <div class="case-study-date-tags flex flex-col gap-[32px]">
            <div
              class="case-study-date-role flex flex-col gap-0"
              aria-label="Project year and role"
            >
              <p class="font-accent text-[32px] text-on-light py-0 my-0">
                {year}
              </p>
              <p class="font-accent text-[32px] text-on-light py-0 my-0">
                Role: <span class="underline">{role}</span>
              </p>
            </div>

            {tags.length > 0 && (
              <ul class="flex flex-wrap gap-2 list-none p-0 m-0" role="list" aria-label="Project tags">
                {tags.map((t) => (
                  <li key={t}>
                    <span class="inline-block rounded-full bg-dark text-white font-accent text-lg md:text-xl px-4 py-1.5 tracking-wide">
                      {t}
                    </span>
                  </li>
                ))}
              </ul>
            )}
          </div>

          {(timeline || results.length > 0) && (
            <div class="case-study-timeline-results pt-2 space-y-5">
              {timeline && (
                <div>
                  <h2 class="font-heading text-[24px] font-semibold text-on-light mb-1 leading-snug">Timeline</h2>
                  <p class="font-heading text-[24px] font-normal text-on-light leading-snug py-0 my-0">{timeline}</p>
                </div>
              )}
              {results.length > 0 && (
                <div>
                  <h2 class="font-heading text-[24px] font-semibold text-on-light mb-2 leading-snug">Results</h2>
                  <ul class="space-y-1.5 font-heading text-[24px] font-normal text-on-light leading-snug list-none p-0 m-0">
                    {results.map((r) => (
                      <li key={r}>{r}</li>
                    ))}
                  </ul>
                </div>
              )}
            </div>
          )}
        </div>

        {cover ? (
          coverFillHeight ? (
            <div class:list={["min-h-[40vh] lg:min-h-0 h-full flex overflow-hidden", coverAlignBottom && "items-end"]}>
              <img
                src={cover}
                alt={coverAlt ?? title}
                class:list={["rounded-2xl w-full h-full min-h-[40vh] lg:min-h-0 object-contain", coverAlignBottom ? "object-bottom" : "object-center"]}
                loading="eager"
                decoding="async"
              />
            </div>
          ) : (
            <img
              src={cover}
              alt={coverAlt ?? title}
              class="rounded-2xl aspect-[16/10] w-full object-cover"
              loading="eager"
              decoding="async"
            />
          )
        ) : (
          <div class="img-placeholder rounded-2xl aspect-[16/10] w-full"></div>
        )}
      </div>
    </header>
    </div>

    {(team.length > 0 || responsibilities.length > 0 || tools.length > 0) && (
      <section
        class="case-study-meta-row w-full bg-dark text-on-dark border-t border-white/10"
        aria-label="Project team, responsibilities, and tools"
      >
        <div
          class:list={[
            "mx-auto w-full px-6 md:px-16 lg:px-24 py-12",
            contentMaxWidth == null && "max-w-4xl",
          ]}
          style={contentMaxWidth != null ? `max-width: ${contentMaxWidth}px` : undefined}
        >
        <div class="grid grid-cols-1 md:grid-cols-3 gap-10 lg:gap-14 items-start w-full">
          <div class="min-w-0">
            <h2 class="font-heading text-xl md:text-2xl font-bold text-on-dark mb-3">Team</h2>
            {team.length > 0 ? (
              <ul class="list-none p-0 m-0 space-y-1 font-body text-base text-on-dark leading-relaxed">
                {team.map((line) => (
                  <li key={line}>{line}</li>
                ))}
              </ul>
            ) : (
              <p class="font-body text-base text-on-dark/50 m-0">—</p>
            )}
          </div>
          <div class="min-w-0">
            <h2 class="font-heading text-xl md:text-2xl font-bold text-on-dark mb-3">Responsibilities</h2>
            {responsibilities.length > 0 ? (
              <ul class="list-none p-0 m-0 space-y-1 font-body text-base text-on-dark leading-relaxed">
                {responsibilities.map((r) => (
                  <li key={r}>{r}</li>
                ))}
              </ul>
            ) : (
              <p class="font-body text-base text-on-dark/50 m-0">—</p>
            )}
          </div>
          <div class="min-w-0">
            <h2 class="font-heading text-xl md:text-2xl font-bold text-on-dark mb-3">Tools</h2>
            {tools.length > 0 ? (
              <ul class="list-none p-0 m-0 space-y-1 font-body text-base text-on-dark leading-relaxed">
                {tools.map((line) => (
                  <li key={line}>{line}</li>
                ))}
              </ul>
            ) : (
              <p class="font-body text-base text-on-dark/50 m-0">—</p>
            )}
          </div>
        </div>
        </div>
      </section>
    )}

    <div
      class:list={[contentMaxWidth != null && "mx-auto"]}
      style={contentMaxWidth != null ? `max-width: ${contentMaxWidth}px` : undefined}
    >
    <section
      class:list={[
        "px-6 md:px-16 lg:px-24 py-16 mx-auto",
        contentMaxWidth == null && "max-w-4xl",
        "[&_h2]:font-heading [&_h2]:!text-[48px] [&_h2]:leading-tight [&_h2]:underline [&_h2]:text-on-light [&_h2]:mt-16 [&_h2]:mb-[64px]",
        "[&_h3]:font-heading [&_h3]:text-2xl [&_h3]:text-on-light [&_h3]:mt-10 [&_h3]:mb-16",
        "[&_p]:font-body [&_p]:text-on-light [&_p]:leading-relaxed [&_p]:mb-6 [&_p]:text-base",
        "[&_ul]:list-disc [&_ul]:pl-6 [&_ul]:mb-6 [&_ul]:space-y-2 [&_ul]:text-on-light",
        "[&_ol]:list-decimal [&_ol]:pl-6 [&_ol]:mb-6 [&_ol]:space-y-2 [&_ol]:text-on-light",
        "[&_blockquote]:border-l-2 [&_blockquote]:border-taupe-500 [&_blockquote]:pl-6 [&_blockquote]:italic [&_blockquote]:text-on-light [&_blockquote]:my-8",
        "[&_img]:rounded-xl [&_img]:my-8 [&_img]:w-full",
        "[&_strong]:text-on-light [&_strong]:font-semibold",
      ]}
    >
      <slot />
      <slot name="appScreens" />
    </section>

    <nav class="px-6 md:px-16 lg:px-24 pb-24 flex justify-between items-center gap-4">
      <div class="flex-1 min-w-0 flex justify-start">
        {otherProjects[0] ? (
          <a
            href={`/work/${otherProjects[0].slug}`}
            class="font-accent text-xl text-on-light hover:opacity-80 transition-opacity inline-flex items-center gap-2"
          >
            <span aria-hidden="true">&larr;</span>
            {otherProjects[0].title}
          </a>
        ) : (
          <span />
        )}
      </div>
      <a
        href="/"
        class="font-accent text-xl text-on-light hover:opacity-80 transition-opacity flex-shrink-0"
      >
        All Projects
      </a>
      <div class="flex-1 min-w-0 flex justify-end">
        {otherProjects[1] ? (
          <a
            href={`/work/${otherProjects[1].slug}`}
            class="font-accent text-xl text-on-light hover:opacity-80 transition-opacity inline-flex items-center gap-2"
          >
            {otherProjects[1].title}
            <span aria-hidden="true">&rarr;</span>
          </a>
        ) : (
          <span />
        )}
      </div>
    </nav>
    </div>
  </article>
</BaseLayout>

<style>
  .heading-expand-right {
    margin-right: calc(50% - 50vw);
  }
  .heading-expand-right .heading-two-lines {
    /* Extend to the right outside the content constraint so heading has room for ~2 lines */
    max-width: calc(100% + 50vw - 50%);
  }
</style>
