---
<div class="haven-pitch-pill my-6">
  <div class="haven-pitch-pill__text font-body leading-relaxed text-center mb-0" style="color: #fff !important;">
    <slot />
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const pill = document.querySelector('.haven-pitch-pill');
    if (!pill) return;
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('haven-pitch-pill--visible');
          }
        });
      },
      { threshold: 0.15, rootMargin: '0px' }
    );
    observer.observe(pill);
  });
</script>

<style>
  .haven-pitch-pill {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    background-color: var(--color-bg-dark);
    color: #fff;
    border-radius: 9999px;
    box-sizing: border-box;
    padding: 32px;
    max-width: 64rem;
    margin-inline: auto;
    opacity: 0;
    transition: opacity 1.2s ease-out;
  }
  .haven-pitch-pill--visible {
    opacity: 1;
  }
  /* :global() ensures slot content (from MDX) gets white — it isn't in this component's scope */
  .haven-pitch-pill :global(*),
  .haven-pitch-pill .haven-pitch-pill__text {
    color: #fff !important;
  }
  .haven-pitch-pill__text,
  .haven-pitch-pill :global(*) {
    font-size: 32px !important;
    line-height: 1.5;
    text-align: center;
  }
  .haven-pitch-pill__text {
    color: #fff !important;
    margin: 0 !important;
    padding: 0 !important;
    width: 100%;
    text-align: center;
  }
  .haven-pitch-pill :global(p) {
    margin-bottom: 0 !important;
  }
</style>
