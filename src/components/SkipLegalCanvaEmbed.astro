---
/**
 * Canva design embed — stays within case study content width (parent max-width).
 */
const embedSrc =
  "https://www.canva.com/design/DAHDDagI7No/H-T836sDFNlT1ZgC5wOHrw/view?embed";
---

<div class="skiplegal-canva-embed">
  <div class="skiplegal-canva-embed__frame">
    <iframe
      src={embedSrc}
      title="SkipLegal final prototype and presentation (Canva)"
      allow="fullscreen"
      allowfullscreen
      loading="lazy"
      class="skiplegal-canva-embed__iframe"
    ></iframe>
  </div>
</div>

<style>
  /* Full width of the case study column only — respects parent max-width + padding */
  .skiplegal-canva-embed {
    width: 100%;
    max-width: 100%;
    margin-block: 1.5rem 2rem;
  }

  .skiplegal-canva-embed__frame {
    position: relative;
    width: 100%;
    max-width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 0.75rem;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(15, 15, 15, 0.12);
    background: #1a1a1a;
  }

  .skiplegal-canva-embed__iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
</style>
