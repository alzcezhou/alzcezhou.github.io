---
/**
 * Pill toggle from Figma (node 569:1135) — scaled 75%, animated knob + labels.
 */
---

<button
  type="button"
  class="haven-harm-toggle haven-harm-toggle--report"
  aria-pressed="false"
  aria-label="Report Harm and Reduce Harm modes"
  data-haven-harm-toggle
>
  <span class="haven-harm-toggle__rail">
    <span class="haven-harm-toggle__label haven-harm-toggle__label--report font-body">Report Harm</span>
    <span class="haven-harm-toggle__label haven-harm-toggle__label--reduce font-body">Reduce Harm</span>
    <span class="haven-harm-toggle__knob" aria-hidden="true"></span>
  </span>
</button>

<script>
  document.querySelectorAll("[data-haven-harm-toggle]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const isReport = btn.classList.toggle("haven-harm-toggle--report");
      btn.classList.toggle("haven-harm-toggle--reduce", !isReport);
      btn.setAttribute("aria-pressed", String(!isReport));
    });
  });
</script>

<style>
  :global(.full-width-dark-banner) .haven-harm-toggle,
  :global(.full-width-dark-banner) .haven-harm-toggle * {
    color: var(--color-text-on-light) !important;
  }

  .haven-harm-toggle {
    flex-shrink: 0;
    position: relative;
    display: block;
    width: 171px;
    max-width: 100%;
    padding: 6px;
    border: none;
    border-radius: 100px;
    cursor: pointer;
    transition: background-color 0.45s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .haven-harm-toggle--report {
    background-color: #d04537;
  }

  .haven-harm-toggle--reduce {
    background-color: #d6e0a4;
  }

  .haven-harm-toggle__rail {
    position: relative;
    display: block;
    width: 100%;
    min-height: 30px;
  }

  .haven-harm-toggle__label {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    font-size: 18px;
    line-height: 1;
    white-space: nowrap;
    pointer-events: none;
    padding-left: 8px;
    padding-right: 8px;
    box-sizing: border-box;
    max-width: calc(100% - 36px);
    transition:
      opacity 0.35s ease,
      visibility 0.35s ease;
  }

  .haven-harm-toggle__label--report {
    left: 0;
    text-align: left;
  }

  .haven-harm-toggle__label--reduce {
    right: 0;
    text-align: right;
  }

  .haven-harm-toggle--report .haven-harm-toggle__label--report {
    opacity: 1;
    visibility: visible;
  }

  .haven-harm-toggle--report .haven-harm-toggle__label--reduce {
    opacity: 0;
    visibility: hidden;
  }

  .haven-harm-toggle--reduce .haven-harm-toggle__label--reduce {
    opacity: 1;
    visibility: visible;
  }

  .haven-harm-toggle--reduce .haven-harm-toggle__label--report {
    opacity: 0;
    visibility: hidden;
  }

  .haven-harm-toggle__knob {
    position: absolute;
    top: 50%;
    left: 0;
    width: 30px;
    height: 30px;
    margin-top: -15px;
    border-radius: 50%;
    background: linear-gradient(180deg, #ffffff 0%, #e0e0e0 100%);
    box-shadow:
      0 2px 5px rgba(0, 0, 0, 0.18),
      0 1px 2px rgba(0, 0, 0, 0.12);
    pointer-events: none;
    transition: left 0.45s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 1;
  }

  .haven-harm-toggle--report .haven-harm-toggle__knob {
    left: calc(100% - 30px);
  }

  .haven-harm-toggle--reduce .haven-harm-toggle__knob {
    left: 0;
  }

  .haven-harm-toggle:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 3px;
  }
</style>
