---
interface Props {
  /** URL or path to .lottie file, e.g. from LottieFiles or "/animations/hero.lottie" */
  src: string;
  size?: number;
  /** Soften crisp edges (px). Default 4. */
  soften?: number;
  class?: string;
}

const { src, size = 600, soften = 4, class: className = "" } = Astro.props;
---

<div class="lottie-hero-wrapper absolute inset-0 flex items-center justify-center pointer-events-none" aria-hidden="true" style={`--lottie-soften: ${soften}px`}>
  <dotlottie-wc
    src={src}
    style={`width: ${size}px; height: ${size}px;`}
    class:list={["lottie-hero-player", className]}
    autoplay
    loop
  />
</div>

<style>
  .lottie-hero-wrapper :global(dotlottie-wc) {
    filter: blur(var(--lottie-soften, 4px)) contrast(0.97);
  }
</style>
