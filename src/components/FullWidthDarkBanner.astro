---
interface Props {
  /** Max width (px) for the inner content; default matches case study content. */
  contentMaxWidth?: number;
}

const { contentMaxWidth = 1128 } = Astro.props;
---

<div class="full-width-dark-banner my-8 md:my-10">
  <div class="full-width-dark-banner__inner" style={`max-width: ${contentMaxWidth}px`}>
    <slot />
  </div>
</div>

<style>
  .full-width-dark-banner {
    width: 100vw;
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
    background-color: var(--color-bg-dark);
    padding: 2rem 1.5rem;
  }
  .full-width-dark-banner__inner {
    margin-left: auto;
    margin-right: auto;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
  }
  @media (min-width: 768px) {
    .full-width-dark-banner__inner {
      padding-left: 2rem;
      padding-right: 2rem;
    }
  }
  @media (min-width: 1024px) {
    .full-width-dark-banner__inner {
      padding-left: 6rem;
      padding-right: 6rem;
    }
  }
  /* :global() ensures slot content (from MDX) gets white — it isn't in this component's scope */
  .full-width-dark-banner :global(*),
  .full-width-dark-banner__inner :global(*) {
    color: #fff !important;
  }
  .full-width-dark-banner__inner :global(p) {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.6;
    margin-bottom: 1rem;
  }
  .full-width-dark-banner__inner :global(p:last-child) {
    margin-bottom: 0;
  }
</style>
