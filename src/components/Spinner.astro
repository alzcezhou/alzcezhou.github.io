---
interface Props {
  size?: number;
  class?: string;
}

const { size = 400, class: className = "" } = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 400 400"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  class:list={["spinner", className]}
  aria-hidden="true"
>
  <!-- Outer ring: 7 large ellipses, all centered, each rotated -->
  <g class="spinner-outer">
    {Array.from({ length: 7 }).map((_, i) => (
      <ellipse
        cx="200"
        cy="200"
        rx="175"
        ry="58"
        stroke="currentColor"
        stroke-width="0.8"
        fill="none"
        opacity="0.55"
        transform={`rotate(${i * (180 / 7)}, 200, 200)`}
      />
    ))}
  </g>

  <!-- Middle ring: 7 ellipses, offset half-step from outer -->
  <g class="spinner-middle">
    {Array.from({ length: 7 }).map((_, i) => (
      <ellipse
        cx="200"
        cy="200"
        rx="130"
        ry="42"
        stroke="currentColor"
        stroke-width="0.7"
        fill="none"
        opacity="0.4"
        transform={`rotate(${i * (180 / 7) + (180 / 14)}, 200, 200)`}
      />
    ))}
  </g>

  <!-- Inner ring: 5 small ellipses for center density -->
  <g class="spinner-inner">
    {Array.from({ length: 5 }).map((_, i) => (
      <ellipse
        cx="200"
        cy="200"
        rx="85"
        ry="28"
        stroke="currentColor"
        stroke-width="0.6"
        fill="none"
        opacity="0.3"
        transform={`rotate(${i * (180 / 5)}, 200, 200)`}
      />
    ))}
  </g>
</svg>

<style>
  @keyframes spin-cw {
    to { transform: rotate(360deg); }
  }
  @keyframes spin-ccw {
    to { transform: rotate(-360deg); }
  }

  .spinner-outer {
    transform-origin: 200px 200px;
    animation: spin-cw 90s linear infinite;
    will-change: transform;
  }
  .spinner-middle {
    transform-origin: 200px 200px;
    animation: spin-ccw 70s linear infinite;
    will-change: transform;
  }
  .spinner-inner {
    transform-origin: 200px 200px;
    animation: spin-cw 110s linear infinite;
    will-change: transform;
  }

  @media (prefers-reduced-motion: reduce) {
    .spinner-outer,
    .spinner-middle,
    .spinner-inner {
      animation: none;
    }
  }
</style>
