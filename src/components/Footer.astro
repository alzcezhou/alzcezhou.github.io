<footer id="site-footer" class="footer-with-video font-accent bg-dark text-on-dark text-[32px]" style="--footer-gif-left: 70px;">
  <div class="footer-media-wrap flex items-center justify-start pr-6 md:pr-16 lg:pr-24" style="padding-left: calc(var(--footer-gif-left) + 2px);">
    <div class="footer-media-inner relative w-full max-w-3xl transition-[margin] duration-150" id="footer-media-inner">
      <img
        id="footer-static"
        class="footer-static block w-full rounded-lg object-contain object-left scale-[0.99] origin-left"
        src="/videos/gif%20still.png"
        alt=""
        aria-hidden="true"
      />
      <img
        id="footer-gif"
        class="footer-gif absolute inset-0 w-full h-full rounded-lg object-contain object-left pointer-events-none"
        src="/videos/footer%20gif.gif"
        alt=""
        aria-hidden="true"
        style="visibility: hidden;"
      />
    </div>
  </div>
  <div class="border-t border-taupe-700/30 px-6 md:px-16 lg:px-24 py-6 flex flex-col md:flex-row justify-between items-center gap-4">
    <p class="tracking-wider">
      Designed &amp; Coded by Alice
    </p>
    <nav aria-label="Footer links" class="flex gap-8 tracking-widest uppercase">
      <a href="https://docs.google.com/document/d/1ccqDIQ8-zdBQ3m-IjK5elowPmIn5jeouF58dEjNE70M/edit?usp=sharing" target="_blank" rel="noopener" class="hover:opacity-80 transition-opacity">Resume</a>
      <a href="mailto:alice@example.com" class="hover:opacity-80 transition-opacity">Email</a>
      <a href="https://www.linkedin.com/in/alzce/" target="_blank" rel="noopener" class="hover:opacity-80 transition-opacity">
        LinkedIn<span class="sr-only"> (opens in new tab)</span>
      </a>
    </nav>
  </div>
</footer>

<script is:inline>
  function initFooterHover() {
    const footer = document.getElementById("site-footer");
    const staticImg = document.getElementById("footer-static");
    const gif = document.getElementById("footer-gif");
    if (!footer || !staticImg || !gif) return;

    const gifSrc = "/videos/footer%20gif.gif";

    const inner = document.getElementById("footer-media-inner");

    footer.addEventListener("mouseenter", () => {
      staticImg.style.visibility = "hidden";
      gif.style.visibility = "";
      gif.src = gifSrc + "?t=" + Date.now();
      if (inner) inner.style.marginLeft = "-2px";
    });

    footer.addEventListener("mouseleave", () => {
      gif.style.visibility = "hidden";
      staticImg.style.visibility = "";
      if (inner) inner.style.marginLeft = "";
    });
  }
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initFooterHover);
  } else {
    initFooterHover();
  }
</script>
