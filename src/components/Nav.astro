---
const links = [
  { label: "About", href: "/about" },
  { label: "Work", href: "/#work" },
  { label: "Resume", href: "#" },
  { label: "Contact", href: "/about#contact" },
];
---

<nav
  class="fixed top-0 inset-x-0 z-50 transition-all duration-300"
  id="main-nav"
  aria-label="Main navigation"
>
  <div class="flex items-center justify-between px-6 md:px-16 lg:px-24 py-5">
    <a href="/" class="font-body text-sm tracking-wider text-charcoal-700">
      Alice Zhou
    </a>

    <ul class="hidden md:flex items-center gap-8">
      {links.map(({ label, href }) => (
        <li>
          <a
            href={href}
            class="font-body text-xs tracking-widest uppercase text-charcoal-600 hover:text-charcoal-700 transition-colors"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <button
      type="button"
      class="md:hidden flex flex-col gap-1.5 p-2 -mr-2"
      id="menu-toggle"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Toggle menu"
    >
      <span class="block w-5 h-px bg-charcoal-700 transition-transform origin-center" id="bar-top"></span>
      <span class="block w-5 h-px bg-charcoal-700 transition-opacity" id="bar-mid"></span>
      <span class="block w-5 h-px bg-charcoal-700 transition-transform origin-center" id="bar-bot"></span>
    </button>
  </div>

  <div
    id="mobile-menu"
    class="md:hidden overflow-hidden max-h-0 transition-[max-height] duration-300 ease-in-out bg-taupe-300/95 backdrop-blur-sm"
    aria-hidden="true"
  >
    <ul class="flex flex-col gap-4 px-6 pb-6 pt-2">
      {links.map(({ label, href }) => (
        <li>
          <a
            href={href}
            class="font-body text-sm tracking-widest uppercase text-charcoal-600 hover:text-charcoal-700 transition-colors"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<script>
  const nav = document.getElementById("main-nav")!;
  const toggle = document.getElementById("menu-toggle")!;
  const menu = document.getElementById("mobile-menu")!;
  const barTop = document.getElementById("bar-top")!;
  const barMid = document.getElementById("bar-mid")!;
  const barBot = document.getElementById("bar-bot")!;

  let open = false;

  function closeMenu() {
    if (!open) return;
    open = false;
    toggle.setAttribute("aria-expanded", "false");
    menu.setAttribute("aria-hidden", "true");
    menu.style.maxHeight = "0";
    barTop.style.transform = "";
    barMid.style.opacity = "";
    barBot.style.transform = "";
  }

  toggle.addEventListener("click", () => {
    open = !open;
    toggle.setAttribute("aria-expanded", String(open));
    menu.setAttribute("aria-hidden", String(!open));

    if (open) {
      menu.style.maxHeight = menu.scrollHeight + "px";
      barTop.style.transform = "rotate(45deg) translate(2px, 2px)";
      barMid.style.opacity = "0";
      barBot.style.transform = "rotate(-45deg) translate(2px, -2px)";
    } else {
      closeMenu();
    }
  });

  menu.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", closeMenu);
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && open) {
      closeMenu();
      toggle.focus();
    }
  });

  let scrolled = false;
  const onScroll = () => {
    const isScrolled = window.scrollY > 60;
    if (isScrolled !== scrolled) {
      scrolled = isScrolled;
      nav.classList.toggle("nav-scrolled", scrolled);
    }
  };
  window.addEventListener("scroll", onScroll, { passive: true });
  onScroll();
</script>
