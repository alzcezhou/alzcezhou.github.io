---
const links = [
  { label: "Home", href: "/" },
  { label: "About", href: "/about" },
  { label: "Work", href: "/#work" },
  { label: "Resume", href: "https://docs.google.com/document/d/1ccqDIQ8-zdBQ3m-IjK5elowPmIn5jeouF58dEjNE70M/edit?usp=sharing", external: true },
  { label: "Contact", href: "/about#contact" },
];
---

<nav
  class="nav fixed top-0 inset-x-0 z-50 transition-all duration-300"
  id="main-nav"
  aria-label="Main navigation"
>
  <div class="nav-row flex items-center justify-between px-6 md:px-16 lg:px-24 py-5">
    <ul class="nav-links items-center gap-8 justify-start">
      {links.map(({ label, href, external }) => (
        <li>
          <a
            href={href}
            class="btn font-accent text-[32px] font-normal leading-normal tracking-widest uppercase transition-colors"
            style="color: rgba(0, 0, 0, 0.75);"
            target={external ? "_blank" : undefined}
            rel={external ? "noopener" : undefined}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <button
      type="button"
      class="btn nav-menu-btn"
      id="menu-toggle"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Toggle menu"
    >
      <span class="block w-5 h-px bg-black transition-transform origin-center" id="bar-top"></span>
      <span class="block w-5 h-px bg-black transition-opacity" id="bar-mid"></span>
      <span class="block w-5 h-px bg-black transition-transform origin-center" id="bar-bot"></span>
    </button>
  </div>

  <div
    id="mobile-menu"
    class="md:hidden overflow-hidden max-h-0 transition-[max-height] duration-300 ease-in-out bg-taupe-300/95 backdrop-blur-sm md:!bg-transparent"
    aria-hidden="true"
  >
    <ul class="flex flex-col gap-3 px-6 pb-6 pt-2 md:px-4 md:py-4 md:gap-2">
      {links.map(({ label, href, external }) => (
        <li>
          <a
            href={href}
            class="nav-dropdown-btn btn font-accent text-[32px] font-normal leading-normal tracking-widest uppercase transition-colors"
            target={external ? "_blank" : undefined}
            rel={external ? "noopener" : undefined}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<script>
  const nav = document.getElementById("main-nav")!;
  const toggle = document.getElementById("menu-toggle")!;
  const menu = document.getElementById("mobile-menu")!;
  const barTop = document.getElementById("bar-top")!;
  const barMid = document.getElementById("bar-mid")!;
  const barBot = document.getElementById("bar-bot")!;

  let open = false;

  function closeMenu() {
    if (!open) return;
    open = false;
    menu.classList.remove("open");
    toggle.setAttribute("aria-expanded", "false");
    menu.setAttribute("aria-hidden", "true");
    menu.style.maxHeight = "0";
    barTop.style.transform = "";
    barMid.style.opacity = "";
    barBot.style.transform = "";
  }

  toggle.addEventListener("click", () => {
    open = !open;
    menu.classList.toggle("open", open);
    toggle.setAttribute("aria-expanded", String(open));
    menu.setAttribute("aria-hidden", String(!open));

    if (open) {
      menu.style.maxHeight = menu.scrollHeight + "px";
      barTop.style.transform = "rotate(45deg) translate(2px, 2px)";
      barMid.style.opacity = "0";
      barBot.style.transform = "rotate(-45deg) translate(2px, -2px)";
    } else {
      closeMenu();
    }
  });

  menu.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", closeMenu);
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && open) {
      closeMenu();
      toggle.focus();
    }
  });

  let scrolled = false;
  const onScroll = () => {
    const isScrolled = window.scrollY > 60;
    if (isScrolled !== scrolled) {
      scrolled = isScrolled;
      nav.classList.toggle("is-collapsed", scrolled);
    }
  };
  window.addEventListener("scroll", onScroll, { passive: true });
  onScroll();
</script>
