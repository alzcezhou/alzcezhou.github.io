---
const links = [
  { label: "Home", href: "/" },
  { label: "About", href: "/about" },
  { label: "Work", href: "/#work" },
  { label: "Resume", href: "https://docs.google.com/document/d/1ccqDIQ8-zdBQ3m-IjK5elowPmIn5jeouF58dEjNE70M/edit?usp=sharing", external: true },
  { label: "Contact", href: "/about#contact" },
];
---

<nav
  class="nav fixed top-0 inset-x-0 z-50 transition-all duration-300"
  id="main-nav"
  aria-label="Main navigation"
>
  <div class="nav-row flex items-center justify-between pl-8 pr-6 md:pr-16 lg:pr-24">
    <ul class="nav-links items-center gap-8 justify-start">
      {links.map(({ label, href, external }) => (
        <li>
          <a
            href={href}
            class="btn font-accent font-normal leading-normal tracking-widest uppercase transition-colors"
            style="color: rgba(0, 0, 0, 0.75);"
            target={external ? "_blank" : undefined}
            rel={external ? "noopener" : undefined}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <button
      type="button"
      class="btn nav-menu-btn"
      id="menu-toggle"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Toggle menu"
    >
      <span class="block w-5 h-px bg-black transition-transform origin-center" id="bar-top"></span>
      <span class="block w-5 h-px bg-black transition-opacity" id="bar-mid"></span>
      <span class="block w-5 h-px bg-black transition-transform origin-center" id="bar-bot"></span>
    </button>
  </div>

  <div
    id="mobile-menu"
    class="mobile-menu-staggered md:hidden overflow-hidden max-h-0 transition-[max-height] duration-300 ease-in-out bg-taupe-300/95 backdrop-blur-sm md:!bg-transparent"
    aria-hidden="true"
    style="max-height: 0;"
  >
    <ul class="flex flex-col gap-3 px-6 pb-6 pt-2 md:px-4 md:py-4 md:gap-2" role="list">
      {links.map(({ label, href, external }) => (
        <li class="nav-stagger-item">
          <a
            href={href}
            class="nav-dropdown-btn btn font-accent text-[32px] font-normal leading-normal tracking-widest uppercase transition-colors"
            target={external ? "_blank" : undefined}
            rel={external ? "noopener" : undefined}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<script>
  function initNav() {
    var nav = document.getElementById("main-nav");
    var toggle = document.getElementById("menu-toggle");
    var menu = document.getElementById("mobile-menu");
    var barTop = document.getElementById("bar-top");
    var barMid = document.getElementById("bar-mid");
    var barBot = document.getElementById("bar-bot");
    if (!nav || !toggle || !menu) return;

    var open = false;

    function closeMenu() {
      if (!open) return;
      open = false;
      menu.classList.remove("open");
      menu.style.maxHeight = "0";
      toggle.setAttribute("aria-expanded", "false");
      menu.setAttribute("aria-hidden", "true");
      if (barTop) barTop.style.transform = "";
      if (barMid) barMid.style.opacity = "";
      if (barBot) barBot.style.transform = "";
    }

    function openMenu() {
      open = true;
      menu.classList.add("open");
      menu.style.maxHeight = "80vh";
      toggle.setAttribute("aria-expanded", "true");
      menu.setAttribute("aria-hidden", "false");
      if (barTop) barTop.style.transform = "rotate(45deg) translate(2px, 2px)";
      if (barMid) barMid.style.opacity = "0";
      if (barBot) barBot.style.transform = "rotate(-45deg) translate(2px, -2px)";
    }

    toggle.addEventListener("click", function () {
      if (open) closeMenu();
      else openMenu();
    });

    var menuLinks = menu.querySelectorAll("a");
    for (var i = 0; i < menuLinks.length; i++) {
      menuLinks[i].addEventListener("click", closeMenu);
    }

    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape" && open) {
        closeMenu();
        toggle.focus();
      }
    });

    var scrolled = false;
    function onScroll() {
      var isScrolled = window.scrollY > 60;
      if (isScrolled !== scrolled) {
        scrolled = isScrolled;
        nav.classList.toggle("is-collapsed", scrolled);
      }
    }
    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();
  }
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initNav);
  } else {
    initNav();
  }
</script>
