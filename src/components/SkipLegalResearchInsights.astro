---
/**
 * Inline SVG via ?raw so dev never hits public/ for these icons (avoids stale Vite
 * requests to wrong paths). Source of truth: src/assets/skiplegal/*.svg
 */
import iconDocumentSvg from "../assets/skiplegal/icon-document.svg?raw";
import iconJudgeSvg from "../assets/skiplegal/icon-judge.svg?raw";
import iconSecuritySvg from "../assets/skiplegal/icon-security.svg?raw";
---
<div class="skiplegal-research-insights space-y-3 my-6">
  <div class="skiplegal-insight">
    <div class="skiplegal-insight__icon" aria-hidden="true" set:html={iconDocumentSvg} />
    <p class="skiplegal-insight__text">
      <strong>Immigration paperwork is overwhelming and repetitive</strong>, even with professional assistance.
    </p>
  </div>
  <div class="skiplegal-insight">
    <div class="skiplegal-insight__icon" aria-hidden="true" set:html={iconJudgeSvg} />
    <p class="skiplegal-insight__text">
      <strong>Trust in AI is conditional.</strong> Users want transparency and proof that the AI is correct.
    </p>
  </div>
  <div class="skiplegal-insight">
    <div class="skiplegal-insight__icon" aria-hidden="true" set:html={iconSecuritySvg} />
    <p class="skiplegal-insight__text">
      <strong>Users expect visible security features</strong> to protect their data.
    </p>
  </div>
</div>

<style>
  .skiplegal-insight {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: clamp(0.75rem, 2.5vw, 2rem);
    background-color: var(--color-bg-dark);
    color: #fff;
    padding-block: 10px;
    padding-inline: 12px;
    border-radius: 0.5rem;
  }
  .skiplegal-insight__icon {
    flex-shrink: 0;
    width: clamp(3rem, 12vw, 5.5rem);
    max-width: min(5.5rem, 100%);
    display: block;
    line-height: 0;
  }
  .skiplegal-insight__icon :global(svg) {
    display: block;
    width: 100%;
    height: auto;
  }
  .skiplegal-insight__text {
    margin: 0;
    flex: 1;
    min-width: 0;
    font-family: var(--font-body);
    font-size: clamp(1rem, 2.2vw, 1.125rem);
    line-height: 1.55;
    color: #fff !important;
  }
  .skiplegal-insight__text strong {
    color: #fff !important;
  }
</style>
