---
interface Props {
  title: string;
  description: string;
  category: string;
  href: string;
  coverAlt: string;
}

const { title, description, category, href, coverAlt } = Astro.props;
---

<a href={href} class="group block">
  <article class="bg-charcoal-500 rounded-2xl overflow-hidden transition-transform duration-300 group-hover:-translate-y-1 grid grid-cols-1 md:grid-cols-[0.9fr_1.1fr] md:min-h-[380px]">
    <div class="p-8 md:py-10 md:pl-10 md:pr-6 flex flex-col justify-between order-2 md:order-1">
      <div>
        <h3 class="font-heading text-3xl md:text-[2.5rem] text-taupe-100 mb-3 leading-tight">
          {title}
        </h3>
        <p class="font-body text-sm text-taupe-300/80 leading-relaxed max-w-sm">
          {description}
        </p>
      </div>
      <p class="font-body text-[10px] tracking-[0.18em] uppercase text-taupe-500 mt-8">
        {category}
      </p>
    </div>
    <div class="img-placeholder aspect-[4/3] md:aspect-auto w-full order-1 md:order-2" role="img" aria-label={coverAlt}>
      <span class="text-taupe-600/60 text-xs font-body px-4 text-center" aria-hidden="true">{coverAlt}</span>
    </div>
  </article>
</a>
