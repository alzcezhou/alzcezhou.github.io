---
interface Props {
  title: string;
  description: string;
  category: string;
  href: string;
  cover?: string; // path in public/, e.g. "/images/work/haven-cover.jpg"
  coverAlt: string;
}

const { title, description, category, href, cover, coverAlt } = Astro.props;
---

<a href={href} class="group block self-stretch">
  <article class="project-card flex flex-col md:flex-row md:justify-between md:items-center py-[46px] px-[48px] rounded-[16px] border border-transparent overflow-hidden group-hover:-translate-y-1 w-full">
    <div class="flex flex-col justify-between items-start flex-shrink-0 self-stretch w-full md:w-[452px] order-2 md:order-1">
      <div>
        <h3 class="font-heading text-3xl md:text-[2.5rem] text-[#FFFFFF] mb-3 leading-tight group-hover:text-on-dark transition-colors duration-300">
          {title}
        </h3>
        <p class="font-body text-[24px] font-normal leading-normal text-bone max-w-sm group-hover:text-on-dark transition-colors duration-300">
          {description}
        </p>
      </div>
      <p class="font-accent text-[24px] font-normal leading-normal text-bone mt-8 group-hover:text-on-dark transition-colors duration-300">
        {category}
      </p>
    </div>
    <div class="aspect-[4/3] md:aspect-auto w-full order-1 md:order-2 rounded-r-[16px] md:rounded-r-[16px] flex items-center justify-center relative overflow-visible">
      <!-- Blurred circle behind image, visible on hover -->
      <div
        class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[581px] h-[581px] rounded-full opacity-0 group-hover:opacity-50 transition-opacity duration-300 pointer-events-none"
        style="background: rgba(103, 103, 103, 0.50); filter: blur(40.85px);"
        aria-hidden="true"
      />
      {cover ? (
        <img
          src={cover}
          alt={coverAlt}
          class="relative z-10 w-full h-full object-cover"
          loading="lazy"
          decoding="async"
        />
      ) : (
        <span class="relative z-10 img-placeholder w-full h-full flex items-center justify-center text-[#FFFFFF]/60 text-xs font-body px-4 text-center group-hover:text-on-dark/80 transition-colors duration-300" aria-hidden="true">{coverAlt}</span>
      )}
    </div>
  </article>
</a>
